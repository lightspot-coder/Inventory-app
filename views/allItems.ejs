<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
  </head>
  <body>
    <h2>All inventory</h2>
    <table>
      <tr>
        <th>genre</th>
        <th>id</th>
        <th>title</th>
        <th>developer</th>
      </tr>
      <% items.map((item) => { %> 
        <tr>
          <td><%= item.genre %></td>
          <td><%= item.id %></td>
          <td><%= item.title %></td>
          <td><%= item.developer %></td>
        </tr>
      <% }) %>
    </table>
    <a href="/">Back to home ...</a>
  </body>
</html>
