<!-- views/partials/errors.ejs -->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="../styles.css"/>
    <title><%=title%></title>
</head>
<body>
     <% if (locals.errors) {%>
    <ul>
        <% errors.forEach(function(error) { %>
        <li><%= error.msg %></li>
        <% }); %>
    </ul>
    <% } %>
</body>
</html>
